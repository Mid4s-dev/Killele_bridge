# --- Application ---
APP_ENV=development               # development | production
APP_SECRET_KEY=change-me-to-a-long-random-secret-at-least-64-chars

# --- Database ---
DATABASE_URL=mysql+pymysql://kilele_user:strongpassword@localhost:3306/kilele_bridge_db

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- IntaSend ---
# Get these from https://developers.intasend.com/
INTASEND_PUBLISHABLE_KEY=ISPubKey_live_xxxxxxxxxxxxxxxx
INTASEND_SECRET_KEY=ISSecretKey_live_xxxxxxxxxxxxxxxx
INTASEND_TEST_MODE=true           # Set to false in production

# --- Payment ---
REGISTRATION_FEE_KES=100
PAYMENT_REDIRECT_URL=https://kilelebridge.co.ke/payment/success
PAYMENT_WEBHOOK_SECRET=change-me-to-a-random-webhook-signing-secret
